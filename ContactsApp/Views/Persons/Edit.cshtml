@model PersonUpdateRequest

@{
    ViewBag.Title="Edit Person";
}

<div class="container py-4">
  <div class="mb-4">
    <h2 class="mb-1">Edit Person</h2>
    <p class="text-muted small mb-0">Fill in the details below to update the contact</p>
  </div>

  <!-- Form Card -->
  <div class="card">
    <div class="card-body">
      @if (ViewBag.Errors != null)
      {
        @foreach (var error in ViewBag.Errors)
        {
          <li>@error</li>
        }
      }


      <form method="post" asp-controller="PersonsController" asp-action="Edit">
        <div class="row g-3">
          <!-- Name -->
          <div class="col-md-6">
            <label for="Name" class="form-label">
              Full Name
              <span class="text-danger" title="Required">*</span>
            </label>
            <input asp-for="Name" class="form-control" placeholder="Enter full name" />
            <span asp-validation-for="Name"></span>

          </div>
          <input type="hidden" asp-for="PersonId"/>

          <!-- Email -->
          <div class="col-md-6">
            <label for="Email" class="form-label">
              Email Address
              <span class="text-danger" title="Required">*</span>
            </label>
            <input asp-for="Email" class="form-control" placeholder="Enter Email address" />
            <span asp-validation-for="Email"></span>
          </div>

          <!-- Date of Birth -->
          <div class="col-md-6">
            <label for="DateOfBirth" class="form-label">Date of Birth</label>
            <input asp-for="DateOfBirth" class="form-control" />
            <span asp-validation-for="DateOfBirth"></span>
          </div>

          <!-- Gender -->
          <div class="col-md-6">
            <label for="Gender" class="form-label">Gender</label>
            @{
              string[] genders = (string[])Enum.GetNames(typeof(GenderOptions));
            }

            @foreach (string gender in genders)
            {
              <input type="radio" asp-for="Gender" value="@gender" />
              <label for="@gender">@gender</label>

            }
            <span asp-validation-for="Gender"></span>
          </div>

          <!-- Date of Birth -->
          <div class="col-md-6">
            <label for="Country" class="form-label">Country</label>
            <select id="Country" asp-for="CountryId" class="form-select" asp-items="@ViewBag.Countries">
              <option value="">Please Select</option>
            </select>
            <span asp-validation-for="CountryId"></span>
          </div>

          <!-- Address -->
          <div class="col-md-6">
            <label for="Address" class="form-label">Address</label>
            <input type="text" asp-for="Address" class="form-control" placeholder="Enter address">
          </div>

          <!-- Newsletter -->
          <div class="col-12">
            <div class="form-check form-switch">
              <input type="checkbox" asp-for="ReceiveNewsLetter" class="form-check-input" value="true">
              <label class="form-check-label" for="ReceiveNewsLetter">
                Subscribe to newsletter
              </label>
            </div>
          </div>

          <!-- Form Actions -->
          <div class="col-12">
            <div class="d-flex gap-2 pt-2">
              <button type="submit" class="btn btn-success">
                <i class="fas fa-save me-1"></i> Create Person
              </button>
              <a asp-action="Index" asp-controller="Persons" class="btn btn-secondary">
                <i class="fas fa-times me-1"></i> Cancel
              </a>
            </div>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Info Section -->
  <div class="alert alert-info mt-4" role="alert">
    <i class="fas fa-info-circle me-2"></i>
    <strong>Required Fields:</strong> Fields marked with <span class="text-danger">*</span> are required
  </div>
</div>
